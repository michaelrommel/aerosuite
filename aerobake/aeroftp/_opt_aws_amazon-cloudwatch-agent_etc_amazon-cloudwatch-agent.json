{
	"agent": {
		"run_as_user": "root",
		"region": "eu-west-2"
	},
	"logs": {
		"logs_collected": {
			"files": {
				"collect_list": [
					{
						"file_path": "/var/log/aeroftp/aeroftp.log",
						"log_group_name": "/aeroftp/backend",
						"log_stream_name": "$INSTANCE_ID",
						"timezone": "UTC",
						"timestamp_format": "%Y-%m-%dT%H:%M:%S"
					}
				]
			}
		}
	}
}
