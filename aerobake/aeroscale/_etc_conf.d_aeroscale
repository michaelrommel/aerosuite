# Configuration for /etc/init.d/aeroscale
#
# Copy this file to /etc/conf.d/aeroscale and adjust the values.
# All settings have safe defaults; only REDIS_URL usually needs changing.

# ── Redis ──────────────────────────────────────────────────────────────────────
# Redis connection URL
# For a local Redis: redis://127.0.0.1:6379
# For a remote Redis with auth: redis://:password@192.168.1.10:6379
export REDIS_URL=rediss://clustercfg.dev-valkey-aeroftp.ak121m.memorydb.${REGION}.amazonaws.com:6379

# ── AWS ────────────────────────────────────────────────────────────────────────
: ${REGION:="${REGION}"}

# Name of the Auto Scaling Group that manages the FTP backends.
: ${ASG_NAME:="aeroftp-backend"}

# AWS CloudWatch namespace for pushed metrics.
: ${CLOUDWATCH_NAMESPACE:="Aeroscale"}

# ── Paths ──────────────────────────────────────────────────────────────────────
# Directory that holds backend-<IP>.weight files.
# Must match the path used by keepalived (created by keepalived start_pre).
: ${WEIGHTS_DIR:="/etc/keepalived/weights"}

# ── Ports ──────────────────────────────────────────────────────────────────────
# Port on which the aeroscale exposes its own aggregated /metrics endpoint.
: ${METRICS_PORT:="9090"}

# Port on which each FTP backend exposes its Prometheus metrics.
: ${SCRAPE_PORT:="9090"}

# ── Tuning ─────────────────────────────────────────────────────────────────────
# Seconds between full state refreshes (snapshot + cleanup + scrape).
# PRODUCTION: 30 s   TEST (10x time-compressed): 3 s
: ${SNAPSHOT_INTERVAL:="3"}

# ── Logging ────────────────────────────────────────────────────────────────────
# tracing log level filter.  Set to "debug" for detailed troubleshooting.
: ${RUST_LOG:="info"}

: ${LOGFILE:="/var/log/aeroscale.log"}

# ── VRRP role detection ────────────────────────────────────────────────────────
# The inside VIP.  aeroscale checks whether this address is assigned to a local
# interface to determine if it is the current VRRP master.
#   Master: full operation (cleanup, termination, CloudWatch, weight persist)
#   Backup: weight sync from Redis, metrics scrape only (no CloudWatch)
# Must match vip_inside configured in aeropulse / keepalived.conf.
# aeroscale reads the inside VIP preferentially from the IMDS instance tag
# aeroftp-vip-inside (set once in the EC2 launch template, propagates to all
# nodes automatically).  This variable is an optional CLI override for
# environments where the IMDS tag is not yet deployed.
: ${VIP_INSIDE:=""}

# ── Weight state persistence ─────────────────────────────────────────────────
# Maximum age (seconds) of Redis weight state before it is considered stale
# and recomputed from current lease state instead of being restored.
# Default: 5 minutes.  Covers the time needed for a rolling upgrade.
: ${WEIGHT_STATE_TTL:="3600"}

# ── Autoscaling ───────────────────────────────────────────────────────────────
# Scale-out is driven by three independent triggers; any one fires a scale-out.
# The hard ceiling (Trigger 3) bypasses the hysteresis counter entirely.
# Triggers 1 and 2 share a single hysteresis counter.

# Trigger 3 — hard connection ceiling (immediate scale-out, no hysteresis).
# Fires when average IPVS sessions per active backend >= this value.
# Default: 1200 (80 % of the 1500 passive-port ceiling).
: ${HARD_CONN_THRESHOLD:="1200"}

# Trigger 1 — smoothed connection-slope floor gate.
# Slope and bandwidth triggers are disarmed below this session count
# to avoid reacting to small idle-time bursts.
: ${SLOPE_LOW_FLOOR:="500"}

# Trigger 1 — smoothed slope threshold in connections per minute.
# Fires when the 6-lag EMA slope of avg_sessions >= this value
# AND avg_sessions >= SLOPE_LOW_FLOOR.
# PRODUCTION value: 25 conn/min (~37 % of the 67 conn/min peak ramp rate).
# TEST value (10x time-compressed runs): 250 conn/min.
: ${SLOPE_THRESHOLD_PER_MIN:="250.0"}

# Trigger 2 — per-backend bandwidth threshold in bytes/s.
# Fires when (eth0 RX bytes/s) / active_backends >= this value
# AND avg_sessions >= SLOPE_LOW_FLOOR.
# Each backend saturates at ~2 Gbit/s inbound; 80 % = 1.6 Gbit/s = 200 MB/s.
: ${BW_THRESHOLD_BPS_PER_BACKEND:="200000000"}

# Maximum IPVS active connections allowed on the busiest remaining backend
# after the drain candidate is removed.  If the worst-case redistribution
# would exceed this, no drain is initiated.  Recommended: 33 % of design max.
: ${DRAIN_THRESHOLD:="200"}

# Number of consecutive snapshot cycles the slope/bandwidth condition must
# persist before a scale-up is taken.  The count is the same for test and
# production; the effective time window scales with SNAPSHOT_INTERVAL:
# PRODUCTION: 3 cycles × 30 s = 90 s   TEST: 3 cycles × 3 s = 9 s
: ${SCALE_UP_HYSTERESIS_CYCLES:="3"}

# Number of consecutive snapshot cycles the drain gate must remain open
# before a drain is initiated.  Independent of SCALE_UP_HYSTERESIS_CYCLES so you
# can make the drain more conservative than the scale-up (or vice-versa).
# PRODUCTION: 9 cycles × 30 s = 270 s   TEST: 9 cycles × 3 s = 27 s
: ${DRAIN_HYSTERESIS_CYCLES:="9"}

# Minimum seconds between two consecutive scale-up actions.
# AWS typically needs 2–3 minutes to bring a new backend InService.
# PRODUCTION: 120 s   TEST (10x time-compressed): 12 s
: ${SCALE_UP_COOLDOWN:="12"}

# Minimum seconds between two consecutive drain initiations.
# PRODUCTION: 300 s   TEST (10x time-compressed): 30 s
: ${DRAIN_COOLDOWN:="30"}

# Percentage difference between IPVS active connections and the backend's
# scraped ftp_sessions_total that triggers a cross-check warning.
# Set to 0 to warn on any non-zero difference.
: ${SCRAPE_MISMATCH_PCT:="10"}

# Whether TerminateInstanceInAutoScalingGroup also decrements the ASG
# desired-capacity counter.
# Set to "false" during testing so the ASG launches a replacement automatically.
# Set to "true" in production to scale the fleet down as backends terminate.
: ${TERM_DECREMENTS_CAPACITY:="true"}

# Seconds an InService instance is allowed to exist without a slot lease
# before aeroscale terminates it.  Termination never decrements desired
# capacity so the ASG immediately launches a replacement.
# Increase if instances need longer to boot and run aeroslot.
: ${ORPHAN_GRACE_SECS:="180"}

# Maximum number of backends allowed in Draining state simultaneously.
# When reached the drain evaluator skips entirely. When below the limit
# with a drain in progress, only a zero-session backend may be added;
# loaded backends wait for the current drain to complete.
: ${MAX_CONCURRENT_DRAINING:="2"}

# ── Safety ────────────────────────────────────────────────────────────────────
# Set to "--dry-run" to log all actions without performing any writes.
# Useful for validating behaviour on a new deployment before going live.
: ${EXTRA_ARGS:=""}
