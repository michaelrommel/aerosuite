# keepalived.conf — wlc FTP pool with FILE_CHECK dynamic weight control

#
# Prerequisites:
#   modprobe ip_vs_ftp
#   (add to /etc/modules-load.d/ipvs.conf for persistence across reboots)
#
# FTP requires NAT mode so that ip_vs_ftp can rewrite PASV responses and
# automatically track data channel connections. DR mode is not supported.
#
# persistence_timeout ensures that the control connection (port 21) and the
# subsequent data connection (passive ephemeral port) from the same client IP
# are always routed to the same backend.
#
# Weight file values per backend:
#   0            → active   (effective weight 1, receives new connections)
#  -1            → draining (effective weight 0, no new connections, existing complete)
#  -2147483648   → removed  (FAULT state, fully absent from IPVS scheduler)
#
# On first start, init_file creates each weight file with -2147483648 (removed).
# On subsequent restarts the existing file content is preserved.
#
# Activate a backend:
#   echo 0 > /etc/keepalived/weights/backend-172.16.32.20.weight
#
# Drain a backend:
#   echo -1 > /etc/keepalived/weights/backend-172.16.32.20.weight
#
# Remove a backend after draining:
#   echo -2147483648 > /etc/keepalived/weights/backend-172.16.32.20.weight

global_defs {
    router_id LVS_01
}

@include /etc/keepalived/vrrp.conf

# ---------------------------------------------------------------------------
# One track_file per backend.
# init_file seeds the file with -2147483648 (FAULT/removed) if it does not
# yet exist. No overwrite — external writes are always preserved on restart.
# ---------------------------------------------------------------------------

track_file backend_172.16.32.20 {
    file "/etc/keepalived/weights/backend-172.16.32.20.weight"
    init_file -2147483648
}
track_file backend_172.16.32.21 {
    file "/etc/keepalived/weights/backend-172.16.32.21.weight"
    init_file -2147483648
}
track_file backend_172.16.32.22 {
    file "/etc/keepalived/weights/backend-172.16.32.22.weight"
    init_file -2147483648
}
track_file backend_172.16.32.23 {
    file "/etc/keepalived/weights/backend-172.16.32.23.weight"
    init_file -2147483648
}
track_file backend_172.16.32.24 {
    file "/etc/keepalived/weights/backend-172.16.32.24.weight"
    init_file -2147483648
}
track_file backend_172.16.32.25 {
    file "/etc/keepalived/weights/backend-172.16.32.25.weight"
    init_file -2147483648
}
track_file backend_172.16.32.26 {
    file "/etc/keepalived/weights/backend-172.16.32.26.weight"
    init_file -2147483648
}
track_file backend_172.16.32.27 {
    file "/etc/keepalived/weights/backend-172.16.32.27.weight"
    init_file -2147483648
}
track_file backend_172.16.32.28 {
    file "/etc/keepalived/weights/backend-172.16.32.28.weight"
    init_file -2147483648
}
track_file backend_172.16.32.29 {
    file "/etc/keepalived/weights/backend-172.16.32.29.weight"
    init_file -2147483648
}
track_file backend_172.16.32.30 {
    file "/etc/keepalived/weights/backend-172.16.32.30.weight"
    init_file -2147483648
}
track_file backend_172.16.32.31 {
    file "/etc/keepalived/weights/backend-172.16.32.31.weight"
    init_file -2147483648
}
track_file backend_172.16.32.32 {
    file "/etc/keepalived/weights/backend-172.16.32.32.weight"
    init_file -2147483648
}
track_file backend_172.16.32.33 {
    file "/etc/keepalived/weights/backend-172.16.32.33.weight"
    init_file -2147483648
}
track_file backend_172.16.32.34 {
    file "/etc/keepalived/weights/backend-172.16.32.34.weight"
    init_file -2147483648
}
track_file backend_172.16.32.35 {
    file "/etc/keepalived/weights/backend-172.16.32.35.weight"
    init_file -2147483648
}
track_file backend_172.16.32.36 {
    file "/etc/keepalived/weights/backend-172.16.32.36.weight"
    init_file -2147483648
}
track_file backend_172.16.32.37 {
    file "/etc/keepalived/weights/backend-172.16.32.37.weight"
    init_file -2147483648
}
track_file backend_172.16.32.38 {
    file "/etc/keepalived/weights/backend-172.16.32.38.weight"
    init_file -2147483648
}
track_file backend_172.16.32.39 {
    file "/etc/keepalived/weights/backend-172.16.32.39.weight"
    init_file -2147483648
}

# ---------------------------------------------------------------------------
# Virtual server
# ---------------------------------------------------------------------------

virtual_server 172.16.29.100 21 {
    lvs_sched    wlc
    lvs_method   NAT       # NAT required — ip_vs_ftp ALG only works in NAT mode
    protocol     TCP

    # ip_vs_ftp rewrites PASV responses and opens IPVS entries for the data
    # channel automatically. persistence_timeout only needs to cover the window
    # from control connection establishment to ip_vs_ftp processing the PASV
    # response (i.e. login + directory navigation time). Once ip_vs_ftp has
    # created the data channel entry, persistence is no longer needed for that
    # transfer. Since each control connection carries exactly one file, there is
    # no need to cover multiple transfers per control connection.
    persistence_timeout 30

    # Pool is healthy as long as at least one backend has weight > 0.
    quorum       1

    # quorum_up/quorum_down can notify an external system when the pool
    # transitions between healthy and empty.
    # quorum_up   "/usr/local/bin/pool-up.sh"
    # quorum_down "/usr/local/bin/pool-down.sh"

    real_server 172.16.32.20 21 {
        weight 1
        FILE_CHECK {
            track_file backend_172.16.32.20
            dynamic
            weight 1
        }
    }
    real_server 172.16.32.21 21 {
        weight 1
        FILE_CHECK {
            track_file backend_172.16.32.21
            dynamic
            weight 1
        }
    }
    real_server 172.16.32.22 21 {
        weight 1
        FILE_CHECK {
            track_file backend_172.16.32.22
            dynamic
            weight 1
        }
    }
    real_server 172.16.32.23 21 {
        weight 1
        FILE_CHECK {
            track_file backend_172.16.32.23
            dynamic
            weight 1
        }
    }
    real_server 172.16.32.24 21 {
        weight 1
        FILE_CHECK {
            track_file backend_172.16.32.24
            dynamic
            weight 1
        }
    }
    real_server 172.16.32.25 21 {
        weight 1
        FILE_CHECK {
            track_file backend_172.16.32.25
            dynamic
            weight 1
        }
    }
    real_server 172.16.32.26 21 {
        weight 1
        FILE_CHECK {
            track_file backend_172.16.32.26
            dynamic
            weight 1
        }
    }
    real_server 172.16.32.27 21 {
        weight 1
        FILE_CHECK {
            track_file backend_172.16.32.27
            dynamic
            weight 1
        }
    }
    real_server 172.16.32.28 21 {
        weight 1
        FILE_CHECK {
            track_file backend_172.16.32.28
            dynamic
            weight 1
        }
    }
    real_server 172.16.32.29 21 {
        weight 1
        FILE_CHECK {
            track_file backend_172.16.32.29
            dynamic
            weight 1
        }
    }
    real_server 172.16.32.30 21 {
        weight 1
        FILE_CHECK {
            track_file backend_172.16.32.30
            dynamic
            weight 1
        }
    }
    real_server 172.16.32.31 21 {
        weight 1
        FILE_CHECK {
            track_file backend_172.16.32.31
            dynamic
            weight 1
        }
    }
    real_server 172.16.32.32 21 {
        weight 1
        FILE_CHECK {
            track_file backend_172.16.32.32
            dynamic
            weight 1
        }
    }
    real_server 172.16.32.33 21 {
